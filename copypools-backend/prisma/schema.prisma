generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ponder_close_event {
  id           String  @id
  position_id  String
  amount0      String
  amount1      String
  tx_hash      String
  block_number Decimal @db.Decimal(78, 0)
  timestamp    Decimal @db.Decimal(78, 0)

  @@map("1750__ponder_close_event")
}

model ponder_compound_event {
  id              String  @id
  position_id     String
  added_liquidity String
  tx_hash         String
  block_number    Decimal @db.Decimal(78, 0)
  timestamp       Decimal @db.Decimal(78, 0)

  @@map("1750__ponder_compound_event")
}

model ponder_position {
  id                   String  @id
  protocol             String
  dex_token_id         String
  owner                String
  token0               String
  token1               String
  active               Boolean @default(true)
  tick_lower           Int?
  tick_upper           Int?
  liquidity            String?
  created_at           Decimal @db.Decimal(78, 0)
  created_tx_hash      String
  created_block_number Decimal @db.Decimal(78, 0)
  updated_at           Decimal @db.Decimal(78, 0)

  @@map("1750__ponder_position")
}

model ponder_range_move_event {
  id              String  @id
  old_position_id String
  new_position_id String
  new_tick_lower  Int
  new_tick_upper  Int
  tx_hash         String
  block_number    Decimal @db.Decimal(78, 0)
  timestamp       Decimal @db.Decimal(78, 0)

  @@map("1750__ponder_range_move_event")
}

model reorg__ponder_close_event {
  id           String
  position_id  String
  amount0      String
  amount1      String
  tx_hash      String
  block_number Decimal @db.Decimal(78, 0)
  timestamp    Decimal @db.Decimal(78, 0)
  operation_id Int     @id @default(autoincrement())
  operation    Int
  checkpoint   String  @db.VarChar(75)

  @@map("1750_reorg__ponder_close_event")
}

model reorg__ponder_compound_event {
  id              String
  position_id     String
  added_liquidity String
  tx_hash         String
  block_number    Decimal @db.Decimal(78, 0)
  timestamp       Decimal @db.Decimal(78, 0)
  operation_id    Int     @id @default(autoincrement())
  operation       Int
  checkpoint      String  @db.VarChar(75)

  @@map("1750_reorg__ponder_compound_event")
}

model reorg__ponder_position {
  id                   String
  protocol             String
  dex_token_id         String
  owner                String
  token0               String
  token1               String
  active               Boolean @default(true)
  tick_lower           Int?
  tick_upper           Int?
  liquidity            String?
  created_at           Decimal @db.Decimal(78, 0)
  created_tx_hash      String
  created_block_number Decimal @db.Decimal(78, 0)
  updated_at           Decimal @db.Decimal(78, 0)
  operation_id         Int     @id @default(autoincrement())
  operation            Int
  checkpoint           String  @db.VarChar(75)

  @@map("1750_reorg__ponder_position")
}

model reorg__ponder_range_move_event {
  id              String
  old_position_id String
  new_position_id String
  new_tick_lower  Int
  new_tick_upper  Int
  tx_hash         String
  block_number    Decimal @db.Decimal(78, 0)
  timestamp       Decimal @db.Decimal(78, 0)
  operation_id    Int     @id @default(autoincrement())
  operation       Int
  checkpoint      String  @db.VarChar(75)

  @@map("1750_reorg__ponder_range_move_event")
}

model ponder_meta {
  key   String @id
  value Json?

  @@map("_ponder_meta")
}

model blockchain_events {
  id           String    @id
  event_type   EventType
  position_id  String?
  tx_hash      String
  block_number Int
  log_index    Int
  event_data   Json
  processed    Boolean   @default(false)
  created_at   DateTime  @default(now())

  @@index([event_type, block_number])
  @@index([position_id])
  @@index([processed])
}

model positions {
  id                    String         @id
  position_id           String         @unique
  protocol              String
  dex_token_id          String
  owner                 String
  token0                String
  token1                String
  active                Boolean        @default(true)
  tick_lower            Int?
  tick_upper            Int?
  liquidity             String?
  last_compound_tx_hash String?
  last_compound_at      DateTime?
  compound_count        Int            @default(0)
  created_at            DateTime       @default(now())
  updated_at            DateTime
  transactions          transactions[]

  @@index([active])
  @@index([owner])
}

model transactions {
  id            String            @id
  position_id   String
  type          TransactionType
  status        TransactionStatus @default(PENDING)
  tx_hash       String?
  block_number  Int?
  gas_used      String?
  metadata      Json?
  error_message String?
  created_at    DateTime          @default(now())
  positions     positions         @relation(fields: [position_id], references: [position_id])

  @@index([position_id])
  @@index([status])
  @@index([type])
}

enum EventType {
  POSITION_OPENED
  POSITION_CLOSED
  RANGE_MOVED
  LIQUIDITY_ADDED
  LIQUIDITY_REMOVED
  FEES_COLLECTED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TransactionType {
  OPEN_POSITION
  CLOSE_POSITION
  MOVE_RANGE
  COMPOUND
  ADD_LIQUIDITY
  REMOVE_LIQUIDITY
}

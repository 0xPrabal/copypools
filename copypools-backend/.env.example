# Network Configuration
NETWORK=sepolia
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CHAIN_ID=11155111

# Contract Addresses (Sepolia)
LP_MANAGER_ADDRESS=0x8260207716eED59209Eb7606489D6bB2cEbC9986
ADAPTER_ADDRESS=0x0a9DC2c5F72d7D7ff25cf23B0CAE1cF1f6583625
POOL_MANAGER_ADDRESS=0x8C4BcBE6b9eF47855f97E675296FA3F6fafa5F1A

# Private Keys (for backend automation)
OPERATOR_PRIVATE_KEY=your_operator_private_key_here

# Database
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=copypools
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/copypools?schema=public

# API Configuration
PORT=3000
API_PREFIX=api/v1

# Monitoring
BLOCK_POLLING_INTERVAL=12000
AUTO_COMPOUND_CHECK_INTERVAL=3600000

# Feature Flags
ENABLE_AUTO_COMPOUND=true
ENABLE_MONITORING=true

# Production Environment Configuration for CopyPools

# Database
DB_PASSWORD=your_secure_postgres_password_here

# Network Configuration
NETWORK=sepolia
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CHAIN_ID=11155111

# Contract Addresses (Sepolia Testnet)
LP_MANAGER_ADDRESS=0x8260207716eED59209Eb7606489D6bB2cEbC9986
ADAPTER_ADDRESS=0x0a9DC2c5F72d7D7ff25cf23B0CAE1cF1f6583625
POOL_MANAGER_ADDRESS=0x8C4BcBE6b9eF47855f97E675296FA3F6fafa5F1A

# Backend Configuration
OPERATOR_PRIVATE_KEY=your_operator_private_key_here
CORS_ORIGIN=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Monitoring
BLOCK_POLLING_INTERVAL=12000
AUTO_COMPOUND_CHECK_INTERVAL=3600000
PONDER_LOG_LEVEL=info

# Feature Flags
ENABLE_AUTO_COMPOUND=true
ENABLE_MONITORING=true

# SSL/TLS Configuration (for production deployment)
# SSL_CERT_PATH=/path/to/ssl/cert.pem
# SSL_KEY_PATH=/path/to/ssl/key.pem

# Domain Configuration (for nginx)
# DOMAIN=your-domain.com

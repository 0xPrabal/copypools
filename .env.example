# ============================================
# COPY POOLS PROTOCOL - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to git!

# ============================================
# NETWORK CONFIGURATION
# ============================================

# Sepolia Testnet RPC URL
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Ethereum Mainnet RPC URL
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ============================================
# WALLET CONFIGURATION
# ============================================

# Deployer private key (DO NOT SHARE!)
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# ============================================
# UNISWAP V4 ADDRESSES - SEPOLIA TESTNET
# ============================================

SEPOLIA_V4_POOL_MANAGER=0xE03A1074c86CFeDd5C142C4F04F1a1536e203543
SEPOLIA_UNIVERSAL_ROUTER=0x3A9D48AB9751398BbFa63ad67599Bb04e4BdF98b
SEPOLIA_POSITION_MANAGER=0x429ba70129df741B2Ca2a85BC3A2a3328e5c09b4
SEPOLIA_STATE_VIEW=0xe1dd9c3fa50edb962e442f60dfbc432e24537e4c
SEPOLIA_QUOTER=0x61b3f2011a92d183c7dbadbda940a7555ccf9227
SEPOLIA_PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3

# ============================================
# UNISWAP V4 ADDRESSES - ETHEREUM MAINNET
# ============================================

MAINNET_V4_POOL_MANAGER=0x000000000004444c5dc75cB358380D2e3dE08A90
MAINNET_PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3

# ============================================
# PROTOCOL CONFIGURATION
# ============================================

# Protocol fee in basis points (100 = 1%, 200 = 2%, max 1000 = 10%)
PROTOCOL_FEE_BPS=200

# Fee collector address (receives protocol fees)
FEE_COLLECTOR_ADDRESS=your_fee_collector_address_here

# Multi-sig wallet address for ownership (mainnet only)
MULTISIG_ADDRESS=your_multisig_address_here

# ============================================
# TRANSACTION SETTINGS
# ============================================

# Default deadline offset in seconds (3600 = 1 hour, 600 = 10 min)
DEFAULT_DEADLINE_OFFSET=3600

# Default slippage tolerance in basis points (50 = 0.5%, 100 = 1%)
DEFAULT_SLIPPAGE_BPS=50

# ============================================
# ETHERSCAN API KEYS
# ============================================

ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ============================================
# GAS REPORTING
# ============================================

REPORT_GAS=true
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_for_gas_reporting

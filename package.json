  "description": "Copy Pools Protocol - Multi-DEX Liquidity Management Layer with Automated Compounding",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",

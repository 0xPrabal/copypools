{
  "name": "copypools",
  "version": "1.0.0",
  "description": "Copypools - Complete liquidity management platform for Uniswap V4",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "resolutions": {
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.19.6"
  },
  "scripts": {
    "build": "yarn workspaces run build",
    "test": "yarn workspaces run test",
    "dev": "yarn workspace @copypools/frontend dev",
    "dev:backend": "yarn workspace @copypools/backend dev",
    "dev:ponder": "yarn workspace ponder dev",
    "dev:full": "concurrently \"yarn dev:backend\" \"yarn dev\" \"yarn dev:ponder\" --names \"backend,frontend,ponder\" --prefix-colors \"blue,green,yellow\"",
    "compile": "yarn --cwd packages/contracts compile",
    "deploy": "yarn --cwd packages/contracts deploy",
    "ponder:codegen": "yarn workspace ponder codegen",
    "ponder:start": "yarn workspace ponder start",
    "prepare": "husky",
    "analyze": "npx ts-node scripts/claude-code-review.ts",
    "analyze:changed": "npx ts-node scripts/claude-code-review.ts --changed",
    "analyze:backend": "npx ts-node scripts/claude-code-review.ts packages/backend/src",
    "analyze:frontend": "npx ts-node scripts/claude-code-review.ts packages/frontend/src",
    "analyze:ponder": "npx ts-node scripts/claude-code-review.ts packages/ponder/src",
    "analyze:contracts": "npx ts-node scripts/claude-code-review.ts packages/contracts/src"
  },
  "keywords": [
    "uniswap",
    "v4",
    "liquidity",
    "defi",
    "copypools",
    "auto-compound",
    "lending"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "lint-staged": {
    "packages/frontend/**/*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'cd packages/frontend && npx tsc --noEmit'"
    ],
    "packages/backend/**/*.ts": [
      "bash -c 'cd packages/backend && npx tsc --noEmit'"
    ]
  }
}

    "deploy:sepolia:production": "hardhat run scripts/deploy-sepolia-production.ts --network sepolia",
    "deploy:mainnet:production": "hardhat run scripts/deploy-mainnet-production.ts --network mainnet",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhat",
    "verify:sepolia": "hardhat verify --network sepolia",
    "verify:mainnet": "hardhat verify --network mainnet",
    "clean": "hardhat clean",
    "typechain": "hardhat typechain"


# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# Network Configuration
NEXT_PUBLIC_NETWORK=sepolia
NEXT_PUBLIC_CHAIN_ID=11155111

# Contract Addresses (Sepolia)
NEXT_PUBLIC_LP_MANAGER_ADDRESS=0x8260207716eED59209Eb7606489D6bB2cEbC9986
NEXT_PUBLIC_ADAPTER_ADDRESS=0x0a9DC2c5F72d7D7ff25cf23B0CAE1cF1f6583625
NEXT_PUBLIC_POOL_MANAGER_ADDRESS=0x8C4BcBE6b9eF47855f97E675296FA3F6fafa5F1A

# Optional: RPC URL for frontend wallet connections
NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Privy Configuration - Get your App ID from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# Environment
NODE_ENV=production

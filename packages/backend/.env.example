# All intervals set to 5 minutes (300000ms) to reduce RPC/API usage
COMPOUND_INTERVAL_MS=300000
AUTO_EXIT_INTERVAL_MS=300000
AUTO_RANGE_INTERVAL_MS=300000
LIQUIDATION_INTERVAL_MS=300000

# Gas Settings (Sepolia typically has low gas)
MAX_GAS_PRICE_GWEI=50
GAS_PRICE_BUFFER_PERCENT=20
